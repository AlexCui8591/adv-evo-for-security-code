#!/usr/bin/env bash
# Copy this file to david_and_goliath/scripts/secrets.sh and fill in your real
# value there. The real secrets.sh file is ignored by git.

# Used by Judge B/C through the OpenAI-compatible CMU AI gateway when
# oracle.api_key is null in the YAML config.
export OPENAI_API_KEY="<paste-your-ai-gateway-key-here>"

# Optional aliases, useful if you write helper scripts later.
export AI_GATEWAY_API_KEY="${OPENAI_API_KEY}"
